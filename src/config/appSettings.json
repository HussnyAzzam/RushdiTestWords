{
  "app": {
    "name": "Super Tools App",
    "version": "1.0.0"
  },
  "textShare": {
    "maxCharacters": 10000,
    "maxDurationHours": 48,
    "defaultDurationHours": 24,
    "pincodeLength": 6,
    "pincodeAlphabet": "0123456789",
    "maxStoredMessages": 1000,
    "encryptionAlgorithm": "XSalsa20-Poly1305",
    "enablePasswordProtection": true,
    "enableFormatPreservation": true,
    "supportedExportFormats": ["txt", "rtf", "docx"]
  },
  "storage": {
    "type": "json-local",
    "cleanupMethod": "frontend-on-access",
    "cleanupIntervalMinutes": 60
  },
  "security": {
    "encryptionLibrary": "tweetnacl.js",
    "textEncoding": "UTF-8"
  }
}
